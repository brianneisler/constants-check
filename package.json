{
  "name": "constants-check",
  "version": "0.3.0",
  "description": "Detect duplicate constants in TypeScript/JavaScript projects and highlight where they exist to drive refactoring",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "constants-check": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli.ts",
    "format": "./scripts/format.sh --fix",
    "format:check": "./scripts/format.sh --check",
    "lint": "./scripts/lint.sh",
    "lint:check": "./scripts/lint.sh --check",
    "typecheck": "./scripts/typecheck.sh",
    "test": "./scripts/test.sh",
    "test:coverage": "./scripts/test.sh --coverage",
    "test:mutation": "stryker run",
    "test:mutation:incremental": "stryker run --incremental",
    "dev-workflow": "./scripts/dev-workflow.sh --auto-fix",
    "dev-workflow:check": "./scripts/dev-workflow.sh",
    "dev-workflow:quick": "./scripts/dev-workflow.sh --auto-fix --skip-tests",
    "prepare": "husky"
  },
  "keywords": [
    "constants",
    "duplicate",
    "refactoring",
    "typescript",
    "javascript",
    "code-quality",
    "cli",
    "ast",
    "linting"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianneisler/constants-check"
  },
  "homepage": "https://github.com/brianneisler/constants-check#readme",
  "bugs": {
    "url": "https://github.com/brianneisler/constants-check/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
